{
    "Debug": {
        "prefix": "phpd",
        "body": [
            "ob_start();",
            "var_dump(\\$${1:variavel});",
            "\\$debugOutput = ob_get_clean();",
            "",
            "echo '<div style=\"background:#101418;color:#e6edf3;border:1px solid #30363d;border-radius:8px;margin:16px 0;font-family:Consolas,Monaco,monospace;font-size:13px;line-height:1.5;box-shadow:0 8px 24px rgba(0,0,0,.18);overflow:hidden;\">';",
            "echo '<div style=\"padding:8px 14px;color:#8b949e;border-bottom:1px solid #30363d;\">${TM_FILENAME}:${TM_LINE_NUMBER} | ' . date('d/m/Y H:i:s') . '</div>';",
            "echo '<pre style=\"margin:0;padding:14px;white-space:pre-wrap;word-break:break-word;color:#d2a8ff;\">' . htmlspecialchars(\\$debugOutput, ENT_QUOTES, 'UTF-8') . '</pre>';",
            "echo '</div>';",
            "die();$0"
        ],
        "description": "Exibe o tipo e o valor de uma variável usando var_dump."
    },
    "Debug JSON": {
        "prefix": "phpdj",
        "body": [
            "die('<pre>' . json_encode(\\$${1:variavel}, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) . '</pre>');$0"
        ],
        "description": "Exibe uma variável formatada como JSON legível e encerra a execução."
    },
    "Debug simples": {
        "prefix": "phpds",
        "body": [
            "echo '<pre>';",
            "var_dump(\\$${1:variavel});",
            "echo '</pre>';",
            "die();$0"
        ],
        "description": "Exibe rapidamente o tipo e o valor de uma variável usando var_dump."
    },
    "PHPDoc completo": {
        "prefix": "phpdoc",
        "body": [
            "/**",
            " * ${1:Descrição objetiva da função ou método.}",
            " *",
            " * @param ${3:array<string, mixed>} \\$${4:dados} ${5:Descrição objetiva do parâmetro.}",
            " * @return ${6:void|bool|int|float|string|array<string, mixed>|object|mixed} ${7:Descrição objetiva do retorno.}",
            " * @throws ${8:\\Throwable} ${9:Quando ocorrer uma falha durante a execução.}",
            " *",
            " * @since ${CURRENT_DATE}/${CURRENT_MONTH}/${CURRENT_YEAR}",
            " * @updated by ${10:Pricila Oliveira} ${CURRENT_DATE}/${CURRENT_MONTH}/${CURRENT_YEAR}",
            " * @author ${11:Pricila Oliveira}",
            " */$0"
        ],
        "description": "Cria um PHPDoc completo com data atual em @since e @updated."
    },
    "PHPDoc atualização": {
        "prefix": "phpdocup",
        "body": [
            " * @updated by ${1:Pricila Oliveira} in ${CURRENT_DATE}/${CURRENT_MONTH}/${CURRENT_YEAR}$0"
        ],
        "description": "Gera linha @updated com autor e data atual."
    },
    "Função com try/catch Throwable": {
        "prefix": "phpfun",
        "body": [
            "${1|public,protected,private|} function ${2:nomeDaFuncao}(${3:array \\$dados}): ${4:array} {",
            "    try {",
            "        ${5:// TODO: implementar regra de negócio}",
            "",
            "        return ${6:[]};",
            "    } catch (\\Throwable \\$th) {",
            "        geralog(\\$th);",
            "",
            "        return ${7:[]};",
            "    }",
            "}$0"
        ],
        "description": "Cria uma função/método PHP com bloco try/catch capturando Throwable e registrando erro com geralog."
    },
    "MySQLi Query Segura Base": {
        "prefix": "mysqlsafe",
        "body": [
            "\\$sql = \"",
            "    ${1:SELECT * FROM tabela}",
            "    ${2:WHERE campo_1 = ? AND campo_2 = ?}",
            "\"; ",
            "",
            "\\$tipos = \"${3:is}\";",
            "\\$valores = [\\$${4:id}, \\$${5:nome}];",
            "",
            "if (strlen(\\$tipos) !== count(\\$valores)) {",
            "    throw new \\InvalidArgumentException('A quantidade de tipos não corresponde à quantidade de valores.');",
            "}",
            "",
            "\\$stmt = \\$this->db->prepare(\\$sql);",
            "",
            "if (!\\$stmt) {",
            "    throw new \\RuntimeException('Erro ao preparar SQL: ' . \\$db->error);",
            "}",
            "",
            "\\$stmt->bindValue(\\$tipos, ...\\$valores);",
            "\\$stmt->execute();",
            "",
            "${6:\\$result = \\$stmt->get_result();}",
            "${7:\\$dados = \\$result->fetchAll(MYSQLI_ASSOC);}",
            "",
            "\\$stmt->close();",
            "",
            "${0:return \\$dados;}"
        ],
        "description": "Cria uma query MySQLi segura usando prepare, bind_param, array de valores e argument unpacking."
    },
    "PDO Query Segura Base": {
        "prefix": "pdosafe",
        "body": [
            "\\$sql = \"",
            "    ${1:SELECT * FROM tabela}",
            "    ${2:WHERE campo_1 = ?}",
            "\";",
            "",
            "\\$valores = [",
            "    \\$${3:valor_1},",
            "];",
            "",
            "\\$stmt = \\$this->db->prepare(\\$sql);",
            "",
            "if (!\\$stmt) {",
            "    throw new \\RuntimeException('Erro ao preparar SQL.');",
            "}",
            "",
            "\\$stmt->execute(\\$valores);",
            "",
            "\\$dados = \\$stmt->fetchAll(PDO::FETCH_ASSOC);",
        ],
        "description": "Cria uma query segura com PDO, prepare e execute usando array de parâmetros."
    }
}
