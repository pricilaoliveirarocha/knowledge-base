{
    // =================== Window & Workspace (Minimalismo) ===================
    "window.zoomLevel": -0.5,
    "workbench.startupEditor": "none",
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "workbench.panel.defaultLocation": "bottom",
    "workbench.sideBar.location": "right",
    "window.commandCenter": false,

    // =================== Editor (UX & Estética) ===================
    "workbench.iconTheme": "material-icon-theme",
    "editor.suggestSelection": "first",
    "editor.fontSize": 13,
    "editor.fontFamily": "'Fira Code'",
    "editor.fontLigatures": true,
    "editor.lineHeight": 19,
    "editor.fontWeight": "300",

    // =================== Tema e Paleta (Feminino & Elegante) ===================
    "workbench.colorCustomizations": {
        "editor.foldBackground": "#00000000",
        "editorFoldingRangeForeground": "#00000000",

        // Guias de Indentação: Cinza leve inativo, Rosa suave ativo
        "editorIndentGuide.background1": "#e2e8f033",
        "editorIndentGuide.activeBackground1": "#f48fb199",

        // Git Gutter: Cores mais pastéis e suaves
        "editorGutter.modifiedBackground": "#60a5fa",
        "editorGutter.addedBackground": "#4ade80",
        "editorGutter.deletedBackground": "#fb7185",
        "minimapGutter.modifiedBackground": "#60a5fa",
        "minimapGutter.addedBackground": "#4ade80",
        "minimapGutter.deletedBackground": "#fb7185",
        "editorOverviewRuler.modifiedForeground": "#60a5fa",
        "editorOverviewRuler.addedForeground": "#4ade80",
        "editorOverviewRuler.deletedForeground": "#fb7185",
    },

    // =================== Editor (Indent / Guides) ===================
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "editor.guides.indentation": true,
    "editor.guides.highlightActiveIndentation": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.guides.bracketPairsHorizontal": true,
    "editor.guides.highlightActiveBracketPair": true,

    // =================== Editor (Auto) ===================
    "editor.autoClosingQuotes": "always",
    "editor.formatOnPaste": false,
    "editor.formatOnSave": true,

    // =================== Emmet ===================
    "emmet.showSuggestionsAsSnippets": true,
    "emmet.includeLanguages": {
        "php": "html",
        "javascriptreact": "javascript",
    },

    // =================== Explorer & Files ===================
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "files.autoSave": "onFocusChange",
    "files.autoSaveDelay": 800,
    "files.exclude": {
        "**.git": true,
        ".pytest_cache": true,
        "**/__pycache__": true,
    },

    // =================== Git ===================
    "git.autofetch": true,
    "git.decorations.enabled": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.openRepositoryInParentFolders": "always",
    "git.ignoreRebaseWarning": true,
    "scm.diffDecorations": "all",
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.codeLens": true,

    // =================== Language Specific (PHP 8.5, JS, Python) ===================
    "intelephense.environment.phpVersion": "8.5.0",
    "intelephense.format.braces": "k&r",
    "intelephense.diagnostics.undefinedSymbols": false,
    "intelephense.diagnostics.undefinedTypes": false,
    "intelephense.diagnostics.typeErrors": false,
    "intelephense.codeLens.usages.enable": true,
    "intelephense.codeLens.references.enable": true,
    "intelephense.codeLens.parent.enable": true,
    "intelephense.codeLens.overrides.enable": true,
    "intelephense.codeLens.implementations.enable": true,

    "[javascript]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[javascriptreact]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[html]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false,
    },
    "[php]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
        "editor.detectIndentation": false,
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[snippets]": {
        "editor.defaultFormatter": "vscode.json-language-features",
    },
    "[vue]": {
        "editor.defaultFormatter": "Vue.volar",
    },
    "[typescriptreact]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[typescript]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },

    // =================== Prettier ===================
    "prettier.enable": true,
    "prettier.printWidth": 200,
    "prettier.semi": false,
    "prettier.singleQuote": true,
    "prettier.tabWidth": 4,
    "prettier.useTabs": false,
    "prettier.bracketSpacing": true,
    "prettier.bracketSameLine": true,
    "prettier.embeddedLanguageFormatting": "auto",
    "prettier.singleAttributePerLine": true,

    // =================== HTML ===================
    "html.format.indentInnerHtml": true,
    "html.format.templating": true,

    // =================== Ferramentas & AI ===================
    "debug.console.closeOnEnd": true,
    "js/ts.suggest.autoImports": true,

    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false,
        "javascript": true,
        "php": true,
    },
    "github.copilot.nextEditSuggestions.enabled": false,
    "github.copilot.nextEditSuggestions.fixes": false,

    "chatgpt.commentCodeLensEnabled": false,
    "chatgpt.localeOverride": null,

    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-5-mini",

    "editor.inlineSuggest.edits.allowCodeShifting": "horizontal",
    "editor.inlineSuggest.edits.showCollapsed": true,

    // =================== Terminal (Minimalista & Elegante) ===================
    "terminal.integrated.fontFamily": "'Cascadia Code', 'Segoe UI Emoji', Consolas, monospace",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.fontWeight": "300",

    // Cursor suave e delicado
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorWidth": 1,
    "terminal.integrated.cursorBlinking": true,

    // Limpeza Visual Extrema
    "terminal.integrated.enableMultiLinePasteWarning": "never",

    // Configuração do Sistema (Git Bash)
    "terminal.integrated.profiles.windows": {
        "Git Bash": {
            "path": "C:\\Program Files\\Git\\bin\\bash.exe",
            "args": ["--login", "-i"],
        },
    },
    "terminal.integrated.initialHint": false,
    "editor.minimap.enabled": false,
    "workbench.colorTheme": "Pink Candy Dark",
}
